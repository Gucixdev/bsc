#!/bin/bash
# bsc-cmd — build/install helper
# usage: bash bsc-cmd <action> [go|py] [-y]
set -e
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="${HOME}/.local/bin"
CFG="${XDG_CONFIG_HOME:-$HOME/.config}/bsc"

ACTION="$1"; shift || true
VARIANT=""
YES=0
for arg in "$@"; do
    case "$arg" in
    go|g|Go)            VARIANT=go ;;
    py|p|python|Python) VARIANT=py ;;
    -y|--yes)           YES=1 ;;
    esac
done

ask_variant() {
    [ -n "$VARIANT" ] && return
    printf "Go or Python? [g/p, default g]: "
    read -r v; [ -z "$v" ] && v=g
    case "$v" in g|go) VARIANT=go ;; *) VARIANT=py ;; esac
}

do_build() {
    ask_variant
    case "$VARIANT" in
    go)
        echo "→ building Go..."
        (cd "$ROOT/go" && CGO_ENABLED=0 go build -ldflags='-s -w' -o "$ROOT/bsc" .)
        echo "✓ $ROOT/bsc  ($(du -sh "$ROOT/bsc" | cut -f1))"
        ;;
    py)
        ENTRY="$ROOT/python/bscmono.py"
        [ -f "$ENTRY" ] || { echo "error: $ENTRY not found" >&2; exit 1; }
        python3 -c "import ast; ast.parse(open('$ENTRY').read()); print('✓ syntax OK')"
        echo "✓ $ENTRY"
        ;;
    esac
}

do_install() {
    ask_variant
    mkdir -p "$BIN" "$CFG"
    if [ -f "$BIN/bsc" ] && [ "$YES" -eq 0 ]; then
        printf "bsc already installed at $BIN/bsc — replace? [y/N]: "
        read -r ans
        [ "$ans" = y ] || [ "$ans" = Y ] || { echo "aborted."; exit 0; }
    fi
    case "$VARIANT" in
    go)
        [ -f "$ROOT/bsc" ] || { echo "error: $ROOT/bsc not found — run build first" >&2; exit 1; }
        cp "$ROOT/bsc" "$BIN/bsc"
        chmod 755 "$BIN/bsc"
        echo "installed → $BIN/bsc"
        ;;
    py)
        printf '#!/bin/bash\nexec python3 "%s/python/bscmono.py" "$@"\n' "$ROOT" > "$BIN/bsc"
        chmod 755 "$BIN/bsc"
        echo "installed → $BIN/bsc (python wrapper)"
        ;;
    esac
    if [ ! -f "$CFG/theme.json" ]; then
        cp "$ROOT/theme/theme.json" "$CFG/theme.json"
        echo "theme → $CFG/theme.json"
    fi
    # bsc-cmd wrapper — put it in PATH if missing
    SELF="$(realpath "${BASH_SOURCE[0]}")"
    if [ ! -f "$BIN/bsc-cmd" ]; then
        printf '#!/bin/bash\nexec bash "%s" "$@"\n' "$SELF" > "$BIN/bsc-cmd"
        chmod 755 "$BIN/bsc-cmd"
        echo "wrapper  → $BIN/bsc-cmd"
    fi
    hash -r
}

do_uninstall() {
    # search PATH + common bin dirs + ~ for files named exactly 'bsc'
    declare -A seen
    candidates=()
    IFS=: read -ra pdirs <<< "$PATH:/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin"
    for dir in "${pdirs[@]}"; do
        [ -n "${seen[$dir]}" ] && continue; seen[$dir]=1
        [ -f "$dir/bsc" ] && candidates+=("$dir/bsc")
    done
    while IFS= read -r f; do
        candidates+=("$f")
    done < <(find "$HOME" -name bsc -type f 2>/dev/null)

    if [ ${#candidates[@]} -eq 0 ]; then
        echo "bsc not found"; return
    fi

    if command -v fzf &>/dev/null; then
        selected=$(printf '%s\n' "${candidates[@]}" | fzf --multi --prompt="select bsc binaries to remove > ")
        [ -z "$selected" ] && { echo "nothing selected"; return; }
    else
        printf '%s\n' "${candidates[@]}"
        printf "remove all? [y/N]: "
        read -r ans
        [ "$ans" = y ] || [ "$ans" = Y ] || { echo "aborted."; return; }
        selected=$(printf '%s\n' "${candidates[@]}")
    fi

    while IFS= read -r bin; do
        if [ -w "$bin" ]; then
            rm -f "$bin" && echo "removed $bin"
        else
            sudo rm -f "$bin" && echo "removed $bin (sudo)"
        fi
    done <<< "$selected"
    hash -r
}


do_info() {
    cat <<EOF
bsc-cmd — build/install helper for bsc

USAGE
  bash bsc-cmd <action> [go|py] [-y]
  bsc-cmd <action> [go|py] [-y]

ACTIONS
  build      compile Go binary  /  validate Python syntax
  install    copy artifact to $BIN; creates bsc-cmd wrapper if missing
  uninstall  remove every 'bsc' binary found in PATH
  info       show this message

FLAGS
  go  g          Go implementation (default)
  py  p  python  Python implementation
  -y  --yes      skip replace confirmation on install

PATHS
  bin    $BIN
  config $CFG

EXAMPLES
  bash bsc-cmd build go
  bash bsc-cmd install go -y
  bsc-cmd build go
  bsc-cmd install go -y
  bsc-cmd uninstall
EOF
}

case "$ACTION" in
build)     do_build ;;
install)   do_install ;;
uninstall) do_uninstall ;;
info)      do_info ;;
"")        echo "usage: bsc-cmd build|install|uninstall|info [go|py] [-y]" >&2; exit 1 ;;
*)         echo "unknown action: $ACTION" >&2; exit 1 ;;
esac
