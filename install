#!/bin/bash
# bsc install — copies script to PATH, optionally installs example theme
# usage: bash install [--prefix /usr/local]

PREFIX="${1:-$HOME/.local}"
BIN="$PREFIX/bin"
CFG="$HOME/.config/bsc"

mkdir -p "$BIN" "$CFG"
CGO_ENABLED=0 go build -ldflags='-s -w' -o bsc bsc.go
cp bsc "$BIN/bsc"

if [ ! -f "$CFG/theme.json" ]; then
    cp theme.json "$CFG/theme.json"
    echo "theme → $CFG/theme.json"
fi

echo "installed → $BIN/bsc"
echo "run: bsc"
